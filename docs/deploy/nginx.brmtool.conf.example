server {
    listen 80;
    server_name deploy-domain.example;
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    server_name deploy-domain.example;

    ssl_certificate /etc/nginx/ssl/deploy-domain.example/fullchain.pem;
    ssl_certificate_key /etc/nginx/ssl/deploy-domain.example/privkey.pem;

    root /var/www/brmtool/admin;
    index index.html;

    client_max_body_size 200m;

    location /api/ {
        proxy_pass http://127.0.0.1:8001/;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
    }

    location /updates/desktop/ {
        alias /var/www/brmtool/updates/desktop/;
        autoindex off;
        add_header Cache-Control "public, max-age=60";
        types {
            application/x-yaml yml yaml;
            application/octet-stream blockmap dmg exe zip;
        }
    }

    location / {
        try_files $uri $uri/ /index.html;
    }
}
